{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "paths": {
      "@athleteos/types": ["./packages/types/src/index.ts"],
      "@athleteos/utils": ["./packages/utils/src/index.ts"],
      "@athleteos/mocks": ["./packages/mocks/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", ".next"]
}
