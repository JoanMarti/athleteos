{
  "name": "@athleteos/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "db:migrate": "typeorm migration:run -d src/database/data-source.ts",
    "db:migrate:generate": "typeorm migration:generate -d src/database/data-source.ts",
    "db:seed": "ts-node src/database/seed.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@athleteos/types": "*",
    "@athleteos/utils": "*",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/swagger": "^7.3.0",
    "@nestjs/typeorm": "^10.0.2",
    "@nestjs/throttler": "^5.1.1",
    "@nestjs/bull": "^10.1.1",
    "bull": "^4.12.2",
    "typeorm": "^0.3.20",
    "pg": "^8.11.3",
    "redis": "^4.6.13",
    "axios": "^1.6.7",
    "class-validator": "^0.14.1",
    "class-transformer": "^0.5.1",
    "helmet": "^7.1.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/testing": "^10.3.0",
    "@types/bull": "^4.10.0",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0",
    "supertest": "^6.3.4",
    "@types/supertest": "^6.0.2"
  }
}
